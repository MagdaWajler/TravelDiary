<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.traveldiary.AddPlannedTripController"
      spacing="15" prefWidth="400"
      style="-fx-padding: 30; -fx-background-color: white;">

    <Label text="Plan Your Next Trip" style="-fx-font-family: 'Arial'; -fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TextField fx:id="titleField" promptText="Trip Title (e.g. Dream Tokyo)" style="-fx-font-family: 'Arial';"/>
    <TextField fx:id="locationField" promptText="Location" style="-fx-font-family: 'Arial';"/>
    <DatePicker fx:id="datePicker" promptText="Target Date" prefWidth="340" style="-fx-font-family: 'Arial';"/>

    <TextField fx:id="durationField" promptText="Duration (e.g. 7 days)" style="-fx-font-family: 'Arial';"/>
    <TextField fx:id="budgetField" promptText="Budget (e.g. $1500)" style="-fx-font-family: 'Arial';"/>

    <TextArea fx:id="goalsArea" promptText="Goals &amp; Things to see..." prefRowCount="4" style="-fx-font-family: 'Arial';"/>

    <Button text="Save Plan" onAction="#onSavePlanClick" prefWidth="340"
            style="-fx-font-family: 'Arial'; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

</VBox>