<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane dividerPositions="0.35" style="-fx-background-color: transparent; -fx-padding: 20;" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.traveldiary.DiscoverController">
    <items>

        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <padding><Insets top="20" right="15" bottom="20" left="15"/></padding>

            <Label text="Discover Places" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
                <VBox.margin><Insets bottom="15"/></VBox.margin>
            </Label>

            <HBox spacing="10">
                <VBox.margin><Insets bottom="15"/></VBox.margin>
                <ToggleButton fx:id="famousPlacesBtn" text="Famous Places" selected="true" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" />
                <ToggleButton fx:id="destinationsBtn" text="Destinations" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" />
            </HBox>

            <TextField fx:id="searchField" promptText="Search country or city..." style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #ecf0f1; -fx-border-radius: 8;">
                <VBox.margin><Insets bottom="15"/></VBox.margin>
            </TextField>

            <ListView fx:id="destinationsListView" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;" />
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0 0 0 20;">
            <content>
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                    <Label fx:id="nameLabel" text="Select a place from the list" wrapText="true" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Label fx:id="countryLabel" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" />

                    <Separator style="-fx-padding: 10 0;" />

                    <HBox spacing="40">
                        <VBox>
                            <Label text="CATEGORY" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;" />
                            <Label fx:id="categoryLabel" style="-fx-font-size: 15px; -fx-text-fill: #34495e;" wrapText="true"/>
                        </VBox>
                        <VBox>
                            <Label text="BEST TIME TO VISIT" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;" />
                            <Label fx:id="bestTimeLabel" style="-fx-font-size: 15px; -fx-text-fill: #34495e;" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-padding: 10 0;" />

                    <Label text="Background &amp; Attractions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label fx:id="backgroundLabel" wrapText="true" style="-fx-font-size: 15px; -fx-text-fill: #34495e; -fx-line-spacing: 5px;"/>

                    <Label fx:id="significanceLabel" wrapText="true" style="-fx-font-size: 15px; -fx-text-fill: #2980b9; -fx-font-style: italic;"/>

                    <Separator style="-fx-padding: 10 0;" />

                    <Label text="Statistics &amp; Info" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                    <Label fx:id="statsLabel" wrapText="true" style="-fx-font-size: 15px; -fx-text-fill: #34495e;"/>
                </VBox>
            </content>
        </ScrollPane>

    </items>
</SplitPane>